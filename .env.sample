# CookMyBots Managed WhatsApp brain service
# Do not add WhatsApp Cloud API credentials here.

PORT=3000
CMB_WHATSAPP_WEBHOOK_SECRET=

# MongoDB is required for persistent watchlists.
MONGODB_URI=

# CookMyBots AI Gateway. Endpoint is a BASE URL, do not append /chat.
# ChainGPT CA analysis is accessed through this gateway with COOKMYBOTS_AI_KEY.
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=
WEB3_CHAT_MODE=on
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20

# Token and security data providers.
DEXSCREENER_API_BASE_URL=https://api.dexscreener.com
GOPLUS_API_KEY=

# Optional explorer keys. Missing keys do not stop the bot.
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
SNOWTRACE_API_KEY=
